SHOPIFY_STORE_DOMAIN=25z1ph-rb.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=REPLACE_ME
SHOPIFY_API_VERSION=2026-04

# Public storefront domain (used for Customer Account API discovery + contact form)
SHOPIFY_PUBLIC_DOMAIN=www.parniknaturals.com

# Customer Account API (OTP login)
CUSTOMER_ACCOUNT_CLIENT_ID=REPLACE_ME
# IMPORTANT: For mobile apps, Shopify Customer Account API redirect URIs should use
# the shop.<shop_id> scheme (see your Customer Accounts URL; shop_id is the number).
# Example for your shop_id 94172840229:
CUSTOMER_ACCOUNT_REDIRECT_URI=shop.94172840229.parnik://auth/callback

